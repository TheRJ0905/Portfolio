<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Rajat Soni | Enterprise Full Stack Engineer & Software Architect</title>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
        theme: {
        extend: {
        "colors": {
        "outline-variant": "rgba(255,255,255,0.4)",
        "error": "#dc2626",
        "surface": "rgba(255,255,255,0.25)",
        "background": "transparent",
        "primary": "var(--theme-primary)",
        "secondary": "var(--theme-secondary)",
        "on-surface": "var(--theme-text-main)",
        "on-surface-variant": "var(--theme-text-sub)"
        },
        "borderRadius": {
        "DEFAULT": "0.5rem",
        "lg": "1rem",
        "xl": "1.5rem",
        "full": "9999px"
        },
        "spacing": {
        "section-gap": "clamp(60px, 8vw, 100px)",
        "gutter": "24px",
        "container-max": "1280px"
        }
        }
        }
        }
    </script>

    <style>
        /* --- DYNAMIC TRANS-SYSTEM THEME TOKENS --- */
        :root {
        --theme-primary: #0058bc;
        --theme-secondary: #0f172a;
        --theme-text-main: #0f172a;
        --theme-text-sub: #475569;
        --theme-dna-a: #0058bc;
        --theme-dna-b: #00bfdb;
        --bg-gradient: radial-gradient(circle at 50% 0%, #f8fafc 10%, #cbd5e1 60%, #94a3b8 100%);
        }

        body.theme-emerald {
        --theme-primary: #059669;
        --theme-secondary: #064e3b;
        --theme-text-main: #064e3b;
        --theme-text-sub: #374151;
        --theme-dna-a: #059669;
        --theme-dna-b: #10b981;
        --bg-gradient: radial-gradient(circle at 50% 0%, #f0fdf4 10%, #bbf7d0 60%, #86efac 100%);
        }

        body.theme-dark {
        --theme-primary: #38bdf8;
        --theme-secondary: #f8fafc;
        --theme-text-main: #f8fafc;
        --theme-text-sub: #cbd5e1;
        --theme-dna-a: #38bdf8;
        --theme-dna-b: #818cf8;
        --bg-gradient: radial-gradient(circle at 50% 0%, #1e293b 10%, #0f172a 60%, #020617 100%);
        }

        body.theme-sunset {
        --theme-primary: #ea580c;
        --theme-secondary: #451a03;
        --theme-text-main: #451a03;
        --theme-text-sub: #4b5563;
        --theme-dna-a: #ea580c;
        --theme-dna-b: #f59e0b;
        --bg-gradient: radial-gradient(circle at 50% 0%, #fff7ed 10%, #ffedd5 60%, #fed7aa 100%);
        }

        html {
        scroll-behavior: smooth;
        overflow-x: hidden;
        }

        body {
        margin: 0;
        padding: 0;
        background: var(--bg-gradient);
        background-attachment: fixed;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        transition: background 0.8s ease;
        }

        .fixed-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
        }

        .cyber-mesh {
        background-image: linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        }

        #floating-canvas {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: auto;
        cursor: crosshair;
        }

        /* --- HIGH-VISIBILITY CHROMOSOMAL DOUBLE STRAND HELIX --- */
        .dna-vertical-viewport {
        position: absolute;
        top: 0;
        left: 50%;
        width: clamp(240px, 28vw, 340px);
        height: 100vh;
        transform: translateX(-50%);
        perspective: 1600px;
        opacity: 0.6;
        transition: opacity 0.4s ease;
        }

        .dna-strand {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
        will-change: transform;
        }

        .dna-node {
        position: absolute;
        width: 100%;
        height: 4px;
        top: var(--node-y);
        transform-style: preserve-3d;
        transform: rotateY(var(--node-rotation));
        }

        .dna-node::before, .dna-node::after {
        content: '';
        position: absolute;
        width: clamp(10px, 1.2vw, 15px);
        height: clamp(10px, 1.2vw, 15px);
        border-radius: 50%;
        background: var(--theme-dna-a);
        top: -5px;
        box-shadow: 0 0 20px 5px var(--theme-dna-a);
        transition: background 0.6s ease, box-shadow 0.6s ease;
        }

        .dna-node::before {
        left: 0;
        }

        .dna-node::after {
        right: 0;
        background: var(--theme-dna-b);
        box-shadow: 0 0 20px 5px var(--theme-dna-b);
        }

        .dna-bar {
        position: absolute;
        left: 10px;
        right: 10px;
        top: 50%;
        height: 2px;
        background: linear-gradient(90deg, var(--theme-dna-a) 0%, var(--theme-dna-b) 100%);
        opacity: 0.5;
        transform: translateY(-50%);
        transition: background 0.6s ease;
        }

        /* --- SPEC-LEVEL APPLE GLASSMORPHISM FRAMEWORKS --- */
        .apple-glass-card {
        background: rgba(255, 255, 255, 0.22) !important;
        backdrop-filter: blur(45px) saturate(230%) !important;
        -webkit-backdrop-filter: blur(45px) saturate(230%) !important;
        border: 1px solid rgba(255, 255, 255, 0.75) !important;
        box-shadow: 0 12px 40px 0 rgba(31, 41, 55, 0.04), inset 0 1px 2px 0 rgba(255, 255, 255, 0.5) !important;
        position: relative;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .apple-dark-glass-card {
        background: rgba(15, 23, 42, 0.3) !important;
        backdrop-filter: blur(45px) saturate(200%) !important;
        -webkit-backdrop-filter: blur(45px) saturate(200%) !important;
        border: 1px solid rgba(255, 255, 255, 0.18) !important;
        box-shadow: 0 16px 48px 0 rgba(0, 0, 0, 0.18), inset 0 1px 1px 0 rgba(255, 255, 255, 0.2) !important;
        position: relative;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .apple-glass-btn {
        background: rgba(255, 255, 255, 0.25) !important;
        backdrop-filter: blur(25px) !important;
        -webkit-backdrop-filter: blur(25px) !important;
        border: 1px solid rgba(255, 255, 255, 0.5) !important;
        box-shadow: 0 4px 16px 0 rgba(0, 0, 0, 0.02) !important;
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        color: var(--theme-text-main) !important;
        }

        .apple-glass-btn:hover {
        background: rgba(255, 255, 255, 0.55) !important;
        border-color: rgba(255, 255, 255, 0.9) !important;
        transform: translateY(-2px);
        }

        .cyber-bracket {
        position: absolute;
        width: 16px;
        height: 16px;
        z-index: 3;
        display: flex;
        align-items: center;
        justify-content: center;
        }

        .cyber-bracket::after {
        content: '🧬';
        font-size: 10px;
        opacity: 0.5;
        transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .bracket-tl {
        top: 4px;
        left: 4px;
        }

        .bracket-tr {
        top: 4px;
        right: 4px;
        }

        .bracket-bl {
        bottom: 4px;
        left: 4px;
        }

        .bracket-br {
        bottom: 4px;
        right: 4px;
        }

        .dna-structural-ribbon {
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.25), transparent);
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
        align-items: center;
        pointer-events: none;
        }

        .dna-ribbon-node {
        font-size: 7px;
        opacity: 0.4;
        transition: all 0.4s ease;
        }

        .apple-glass-card:hover {
        background: rgba(255, 255, 255, 0.4) !important;
        border-color: rgba(255, 255, 255, 1) !important;
        box-shadow: 0 24px 50px 0 rgba(0, 88, 188, 0.08), inset 0 1px 3px 0 rgba(255, 255, 255, 0.7) !important;
        transform: translateY(-4px);
        }

        .apple-dark-glass-card:hover {
        background: rgba(15, 23, 42, 0.4) !important;
        border-color: rgba(255, 255, 255, 0.35) !important;
        box-shadow: 0 24px 50px 0 rgba(0, 0, 0, 0.3) !important;
        transform: translateY(-4px);
        }

        .apple-glass-card:hover .cyber-bracket::after,
        .apple-dark-glass-card:hover .cyber-bracket::after {
        opacity: 1;
        transform: scale(1.3) rotate(360deg);
        }

        .hover-runtime-status {
        transition: all 0.4s ease;
        }

        .hover-runtime-status:hover {
        transform: scale(1.02);
        background: rgba(255, 255, 255, 0.45) !important;
        }

        .hover-runtime-status:hover .material-symbols-outlined {
        transform: rotate(180deg);
        }

        .hover-metric-block {
        transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .hover-metric-block:hover {
        background: rgba(255, 255, 255, 0.45) !important;
        border-color: var(--theme-primary) !important;
        transform: scale(1.02);
        }

        .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.8s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .reveal.active {
        opacity: 1;
        transform: translateY(0);
        }

        .blue-highlight-company {
        color: var(--theme-primary) !important;
        font-weight: 700;
        transition: color 0.4s ease;
        }
    </style>
</head>
<body ng-app="portfolioApp" ng-controller="PortfolioController" class="relative">

