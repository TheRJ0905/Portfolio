    <script>
        var app = angular.module('portfolioApp', []);

        app.controller('PortfolioController', ['$scope', '$window', function($scope, $window) {

        $scope.profileData = {
        name: "Rajat Soni",
        systemNode: "SYS_RICH_DASHBOARD"
        };

        // Detailed Capability Metadata Schema Models
        $scope.activeCapability = 'all';
        $scope.capabilityDetails = {
        'all': { title: "Complete System Topology Horizon", desc: "Displaying full structural architecture proficiency boundaries mapping optimized backends directly onto synchronized frontend display spaces." },
        'backend': { title: "High-Throughput C# Server Internals", desc: "Engineered cleanly using Entity Framework Core tracking management, relational table partitioning maps, structured Domain Context structures, and highly optimized database files processing queries in less than 2.4ms under execution profiles." },
        'cross-platform': { title: "Native Cross-Tier Client Deliveries", desc: "Compiling modular Flutter device systems bound tightly to local databases using background workers, offline synchronization pools, and BLOC state orchestration paradigms rendering smoothly at 60 FPS." },
        'frontend': { title: "Responsive Control Environments", desc: "Structuring predictable user interface controls backed by script asset files, asynchronous jQuery payload mappings, and utility-first layout wrappers like Tailwind CSS and Bootstrap." }
        };

        $scope.selectCapability = function(cap) {
        $scope.activeCapability = cap;
        pushSystemLog("[SYS_FILTER] Refocused dashboard control parameters to capability tier: " + cap);
        };

        // Dynamic Projects Presentation Filters
        $scope.activeProjectFilter = 'all';
        $scope.selectProjectFilter = function(filter) {
        $scope.activeProjectFilter = filter;
        pushSystemLog("[SYS_WORK] Altered deployment query boundaries to category: " + filter);
        };

        $scope.shouldShowProject = function(projTag, capTag) {
        var matchesProj = ($scope.activeProjectFilter === 'all' || $scope.activeProjectFilter === projTag);
        var matchesCap = ($scope.activeCapability === 'all' || $scope.activeCapability === capTag);
        return matchesProj && matchesCap;
        };

        // Dynamic Terminal Logging Helper
        function pushSystemLog(text) {
        var logEl = document.getElementById('system-live-log');
        if(logEl) { logEl.innerText = " " + text; }
        }

        $scope.changeTheme = function(themeName) {
        var body = document.body;
        body.className = "relative";
        if(themeName !== 'default') body.classList.add('theme-' + themeName);
        pushSystemLog("[SYS_THEME] Initialized macro " + themeName + " style context tokens.");
        };

        $scope.navLinks = [
        { title: "Terminal", url: "#hero", active: true },
        { title: "Control Panel", url: "#control-panel", active: false },
        { title: "About", url: "#about", active: false },
        { title: "Projects", url: "#projects", active: false }
        ];

        $scope.setActiveLink = function(selectedLink) {
        angular.forEach($scope.navLinks, function(link) {
        link.active = (link.title === selectedLink.title);
        });
        pushSystemLog("[SYS_NAV] Transferred viewing plane focus to " + selectedLink.title + " content section.");
        };

        $scope.metrics = [
        { value: "04+", label: "Years Experience" },
        { value: "25+", label: "Production Deployments" }
        ];

        $scope.keySkills = [
        { title: "SQL Server Optimization", icon: "database", category: "backend", description: "Advanced database normalization, query execution plan analysis, strategic index tuning, and highly performant stored procedures." },
        { title: "Entity Framework Core", icon: "layers", category: "backend", description: "Configuring optimal query execution strategies, compiled queries, change tracking control, and handling complex migration environments." },
        { title: "Clean Architecture & DDD", icon: "token", category: "backend", description: "Isolating core business entities using bounded contexts, clear application domain separation, and highly testable unit boundaries." },
        { title: "Cross-Platform Delivery", icon: "phone_android", category: "cross-platform", description: "Building highly responsive Flutter applications backed by robust offline caching patterns and state orchestration models." },
        { title: "Enterprise Integrations", icon: "api", category: "backend", description: "Authoring highly secure custom JSON middleware layers, standardized API responses, and resilient third-party messaging integrations." },
        { title: "Frontend Orchestration", icon: "code", category: "frontend", description: "Structuring asynchronous script layers using JavaScript, jQuery, and utility-first styling patterns like Tailwind CSS and Bootstrap." }
        ];

        // Scroll Helix Chain Engine
        var dnaStrandElement = document.getElementById('scroll-dna-strand');
        var idleBaseRotation = 0;
        var currentScrollRotation = 0;

        function updateHybridDNALoop() {
        idleBaseRotation += 0.2;
        var winScrollTop = $window.pageYOffset || document.documentElement.scrollTop;
        var targetScrollRotation = winScrollTop * 0.15;
        currentScrollRotation += (targetScrollRotation - currentScrollRotation) * 0.08;

        if (dnaStrandElement) {
        var totalRotation = idleBaseRotation + currentScrollRotation;
        dnaStrandElement.style.transform = 'rotateY(' + totalRotation + 'deg)';
        }
        $window.requestAnimationFrame(updateHybridDNALoop);
        }
        $window.requestAnimationFrame(updateHybridDNALoop);

        // ====================================================================
        // GAMIFIED INTERACTIVE COLLISION ENGINE WITH CLICK TARGETS
        // ====================================================================
        (function initKineticEngine() {
        var canvas = document.getElementById('floating-canvas');
        if(!canvas) return;
        var ctx = canvas.getContext('2d');

        var techAndBioNodes = ['⚡ C#', '.NET Core', '🛢️ SQL Server', '☁️ Azure', '💻 VS', '📱 Flutter', '🌐 REST API', '🧬 A', '🧬 T', '🧬 C', '🧬 G'];
        var particles = [];
        var sparks = [];
        var ripples = [];
        var mouse = { x: null, y: null };

        function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);

        canvas.addEventListener('mousemove', function(e) {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
        });
        canvas.addEventListener('mouseleave', function() {
        mouse.x = null;
        mouse.y = null;
        });

        canvas.addEventListener('click', function(e) {
        var clickX = e.clientX;
        var clickY = e.clientY;
        var hitDetected = false;

        ripples.push({ x: clickX, y: clickY, r: 2, maxR: 45, alpha: 1.0 });

        for(var i = 0; i < particles.length; i++) {
        var p = particles[i];
        var hitWidth = p.text.length * 7;
        if(clickX >= p.x - 10 && clickX <= p.x + hitWidth && clickY >= p.y - 15 && clickY <= p.y + 5) {
        hitDetected = true;
        createSparkCluster(p.x + (hitWidth/2), p.y, 25);
        pushSystemLog("[SYS_KINETIC] User neutralized vector node spatial point: " + p.text);

        p.x = Math.random() * canvas.width;
        p.y = Math.random() * canvas.height;
        }
        }
        });

        resizeCanvas();

        for (var i = 0; i < 22; i++) {
        particles.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        text: techAndBioNodes[i % techAndBioNodes.length],
        speedX: (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 1.0 + 1.2),
        speedY: (Math.random() > 0.5 ? 1 : -1) * (Math.random() * 1.0 + 1.2),
        opacity: Math.random() * 0.35 + 0.25
        });
        }

        function createSparkCluster(x, y, count) {
        var amt = count || 10;
        for(var k = 0; k < amt; k++) {
        sparks.push({ x: x, y: y, vx: (Math.random() - 0.5) * 7, vy: (Math.random() - 0.5) * 7, alpha: 1.0, size: Math.random() * 2.5 + 1 });
        }
        }

        function drawFrame() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        var activeThemeColor = getComputedStyle(document.documentElement).getPropertyValue('--theme-primary').trim();

        for (var a = 0; a < particles.length; a++) {
        for (var b = a + 1; b < particles.length; b++) {
        var dist = Math.hypot(particles[a].x - particles[b].x, particles[a].y - particles[b].y);
        if (dist < 130) {
        ctx.strokeStyle = activeThemeColor;
        ctx.globalAlpha = (1.0 - (dist / 130)) * 0.15;
        ctx.lineWidth = 0.5;
        ctx.beginPath();
        ctx.moveTo(particles[a].x, particles[a].y);
        ctx.lineTo(particles[b].x, particles[b].y);
        ctx.stroke();
        }
        }
        }
        ctx.globalAlpha = 1.0;

        for (var r = ripples.length - 1; r >= 0; r--) {
        var rip = ripples[r];
        rip.r += 2.5;
        rip.alpha -= 0.04;
        if(rip.alpha <= 0) { ripples.splice(r, 1); continue; }
        ctx.strokeStyle = activeThemeColor;
        ctx.globalAlpha = rip.alpha;
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.arc(rip.x, rip.y, rip.r, 0, Math.PI * 2);
        ctx.stroke();
        }
        ctx.globalAlpha = 1.0;

        ctx.font = "bold 12px 'JetBrains Mono', monospace";
        particles.forEach(function(p) {
        p.x += p.speedX;
        p.y += p.speedY;

        if(mouse.x !== null && mouse.y !== null) {
        var mDist = Math.hypot(p.x - mouse.x, p.y - mouse.y);
        if(mDist < 110) {
        var forceX = (p.x - mouse.x) / mDist;
        var forceY = (p.y - mouse.y) / mDist;
        p.x += forceX * 4.5;
        p.y += forceY * 4.5;
        }
        }

        if (p.x < 10) { p.speedX *= -1; p.x = 10; createSparkCluster(p.x, p.y, 8); }
        if (p.x > canvas.width - 60) { p.speedX *= -1; p.x = canvas.width - 60; createSparkCluster(p.x, p.y, 8); }
        if (p.y < 15) { p.speedY *= -1; p.y = 15; createSparkCluster(p.x, p.y, 8); }
        if (p.y > canvas.height - 15) { p.speedY *= -1; p.y = canvas.height - 15; createSparkCluster(p.x, p.y, 8); }

        ctx.fillStyle = activeThemeColor;
        ctx.globalAlpha = p.opacity;
        ctx.fillText(p.text, p.x, p.y);
        });

        for (var s = sparks.length - 1; s >= 0; s--) {
        var sp = sparks[s];
        sp.x += sp.vx;
        sp.y += sp.vy;
        sp.alpha -= 0.03;
        if (sp.alpha <= 0) { sparks.splice(s, 1); continue; }
        ctx.fillStyle = activeThemeColor;
        ctx.globalAlpha = sp.alpha;
        ctx.beginPath();
        ctx.arc(sp.x, sp.y, sp.size, 0, Math.PI * 2);
        ctx.fill();
        }
        ctx.globalAlpha = 1.0;
        requestAnimationFrame(drawFrame);
        }
        requestAnimationFrame(drawFrame);
        })();

        var revealElements = document.querySelectorAll('.reveal');
        var revealObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) { if (entry.isIntersecting) entry.target.classList.add('active'); });
        }, { threshold: 0.05 });
        revealElements.forEach(function(el) { revealObserver.observe(el); });
        }]);
    </script>
</body>
</html>