            <div class="flex justify-between items-center max-w-container-max mx-auto px-4 md:px-8 h-16 relative">
                <div class="flex items-center gap-2 group cursor-pointer">
                    <span class="text-sm">🧬</span>
                    <span class="font-bold tracking-tight text-base md:text-lg" style="color: var(--theme-text-main);">RAJAT SONI</span>
