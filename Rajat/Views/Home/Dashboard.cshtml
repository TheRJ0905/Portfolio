@{
    // Completely bypasses the default shared layout container to ensure pure edge-to-edge fullscreen execution
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="m-0 p-0 w-full h-full overflow-hidden">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport" />
    <title>Enterprise E-commerce Dashboard | Real-Time Telemetry Control Console</title>

    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@100..700" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <script id="tailwind-config">
        tailwind.config = {
        theme: {
        extend: {
        "colors": {
        "outline-variant": "rgba(255,255,255,0.4)",
        "error": "#dc2626",
        "surface": "rgba(255,255,255,0.25)",
        "background": "transparent",
        "primary": "var(--theme-primary)",
        "secondary": "var(--theme-secondary)",
        "on-surface": "var(--theme-text-main)",
        "on-surface-variant": "var(--theme-text-sub)"
        },
        "borderRadius": {
        "DEFAULT": "0.5rem",
        "lg": "1rem",
        "xl": "1.5rem",
        "full": "9999px"
        }
        }
        }
        }
    </script>
    <link href="~/css/dashboard.css" rel="stylesheet" />
    
</head>
<body ng-app="dashboardApp" ng-controller="ConsoleController" class="m-0 p-0 w-full h-full overflow-hidden select-none">

    <!-- CANVAS LAYERS -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <div class="absolute w-[450px] h-[450px] rounded-full bg-purple-400/25 blur-[100px] bottom-[-50px] left-[-50px] animate-pulse"></div>
        <div class="absolute w-[400px] h-[400px] rounded-full bg-emerald-300/20 blur-[110px] top-[-50px] right-[-50px] animate-pulse"></div>
        <canvas id="floating-canvas" class="w-full h-full"></canvas>
    </div>

    <!-- GLOBAL FLOATING AQI WIDGET -->
    <div class="fixed bottom-6 right-6 z-[100] aqi-float-widget p-4 rounded-2xl flex items-center gap-4 transition-all hover:scale-105 cursor-pointer group">
        <div class="w-12 h-12 rounded-full bg-emerald-500/20 flex items-center justify-center border border-emerald-400">
            <span class="material-symbols-outlined text-emerald-600 dark:text-emerald-400 text-2xl group-hover:animate-spin">air</span>
        </div>
        <div>
            <div class="flex items-center gap-2">
                <span class="text-[10px] font-mono font-bold tracking-widest uppercase opacity-70" ng-style="{color: 'var(--theme-text-sub)'}">Current AQI</span>
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
            </div>
            <h3 class="text-xl font-black text-emerald-600 dark:text-emerald-400 leading-tight">{{aqiValue}} <span class="text-xs font-bold font-sans tracking-normal opacity-80">{{aqiStatus}}</span></h3>
            <p class="text-[9px] font-mono opacity-60" ng-style="{color: 'var(--theme-text-main)'}">Loc: {{currentCityName}}</p>
        </div>
    </div>

    <!-- MASTER WORKSPACE ENVIRONMENT CONTAINER -->
    <div class="glass-desktop-workspace flex items-stretch relative z-10 overflow-hidden">

        <!-- SIDEBAR LEFT NAVIGATION PANEL -->
        <aside class="hidden md:flex w-64 border-r border-slate-900/5 dark:border-white/5 p-5 flex-col justify-between gap-6 shrink-0 z-20">
            <div class="space-y-5">
                <div class="flex items-center justify-between px-1">
                    <div class="flex items-center gap-2.5">
                        <span class="p-2 bg-blue-600 text-white rounded-xl shadow-md material-symbols-outlined text-sm font-bold">shopping_cart</span>
                        <span class="font-black text-sm tracking-tight transition-colors" ng-style="{color: 'var(--theme-text-main)'}">E-commerce OS</span>
                    </div>
                </div>

                <nav class="space-y-0.5">
                    <button ng-click="switchActiveView('overview')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'overview', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'overview'}">
                        <span class="material-symbols-outlined text-base">space_dashboard</span>Dashboard Home
                    </button>
                    <!-- NEW CUSTOMER DETAILS MENU ITEM -->
                    <button ng-click="switchActiveView('add_customer')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'add_customer', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'add_customer'}">
                        <span class="material-symbols-outlined text-base">person_add</span>Add Customer Details
                    </button>
                    <button ng-click="switchActiveView('customers')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'customers', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'customers'}">
                        <span class="material-symbols-outlined text-base">group</span>Customer Registry
                    </button>
                    <button ng-click="switchActiveView('shipping')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'shipping', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'shipping'}">
                        <span class="material-symbols-outlined text-base">map</span>Shipping & Maps
                    </button>
                    <div class="pt-2 pb-2">
                        <div class="px-3 text-[9px] font-mono font-bold tracking-widest text-slate-400 uppercase">// Data Forms</div>
                    </div>
                    <button ng-click="switchActiveView('orders')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'orders', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'orders'}">
                        <span class="material-symbols-outlined text-base">receipt_long</span>Neumorphic Orders
                    </button>
                    <button ng-click="switchActiveView('products')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'products', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'products'}">
                        <span class="material-symbols-outlined text-base">inventory_2</span>Obsidian Products
                    </button>
                    <button ng-click="switchActiveView('finances')" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-xs font-bold transition-all" ng-class="{'active-blue-link': activeView === 'finances', 'text-slate-600 hover:bg-black/5 dark:text-slate-400': activeView !== 'finances'}">
                        <span class="material-symbols-outlined text-base">account_balance_wallet</span>Sunset Finances
                    </button>
                </nav>
            </div>

            <!-- Sidebar Footer Configuration Base -->
            <div class="space-y-3 pt-3 border-t border-slate-900/5 dark:border-white/5">
                <div class="text-[9px] font-mono font-bold uppercase tracking-wider mb-1" ng-style="{color: 'var(--theme-text-sub)'}">// MUTATE COLOR MATRIX:</div>
                <div class="grid grid-cols-4 gap-1 bg-black/5 dark:bg-white/5 p-1 rounded-xl">
                    <button ng-click="changeTheme('default')" class="w-full h-5 rounded bg-blue-600 border border-white/40 shadow-sm" title="Blue Helix"></button>
                    <button ng-click="changeTheme('emerald')" class="w-full h-5 rounded bg-emerald-600 border border-white/40 shadow-sm" title="Emerald Gene"></button>
                    <button ng-click="changeTheme('sunset')" class="w-full h-5 rounded bg-orange-600 border border-white/40 shadow-sm" title="Sunset Strand"></button>
                    <button ng-click="changeTheme('dark')" class="w-full h-5 rounded bg-slate-500 border border-white/40 shadow-sm" title="Obsidian Dark"></button>
                </div>
                <div class="flex items-center gap-2.5 px-1 pt-2">
                    <div class="w-8 h-8 rounded-full border border-white flex items-center justify-center text-xs font-bold text-white bg-slate-800 shadow-sm">RS</div>
                    <div class="truncate">
                        <div class="text-xs font-bold transition-colors" ng-style="{color: 'var(--theme-text-main)'}">Rajat Soni</div>
                        <div class="text-[9px] text-slate-500 font-mono">rajat.soni547@gmail.com</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- PANEL DASHBOARD MAIN CONTENT SCROLL GRID -->
        <main class="flex-grow p-4 md:p-6 overflow-y-auto custom-scrollbar flex flex-col gap-6 z-20 h-full pb-32">

            <!-- CONTROLS HEADER -->
            <header class="flex flex-col sm:flex-row justify-between sm:items-center gap-4 border-b border-slate-900/5 dark:border-white/5 pb-4">
                <div>
                    <h2 class="text-lg font-bold tracking-tight transition-colors" ng-style="{color: 'var(--theme-text-main)'}">Hi, Rajat</h2>
                    <p class="text-xs text-slate-500">Welcome back to analytics console overview.</p>
                </div>
                <div class="flex items-center gap-2 text-xs">
                    <span class="px-2 py-1 font-mono text-[9px] rounded bg-blue-500/10 text-blue-500 font-bold animate-pulse">● TELESCOPIC_CLUSTER_STREAM_ON</span>
                </div>
            </header>

            <!-- LIVE LOGS ACTIVITY ROLLING TELEMETRY TICKER -->
            <div class="flex items-center gap-2 bg-black/10 dark:bg-white/5 border border-white/20 rounded-xl px-4 py-2 font-mono text-[11px] shadow-inner" ng-style="{color: 'var(--theme-text-main)'}">
                <span class="text-primary animate-pulse font-bold">● SYSTEM LOGS:</span>
                <span id="system-live-log" class="truncate transition-all duration-300">Synchronizing concentric network channels...</span>
            </div>

            <!-- ====================================================================
                 FIXED STABLE COMMUNICATION HUB CONTROLS CARD
                 ==================================================================== -->
            <section class="glass-card p-5 rounded-2xl flex flex-col sm:flex-row justify-between items-center gap-4 border border-white/60 relative overflow-hidden shrink-0">
                <div class="absolute top-1.5 right-4 font-mono text-[8px] opacity-40">// SYSTEM USER ACCOUNT REGISTRY LINK</div>

                <div class="flex items-center gap-4 w-full sm:w-auto">
                    <div class="w-12 h-12 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-400 text-white flex items-center justify-center font-bold font-mono shadow-md text-base shrink-0">RS</div>
                    <div class="truncate">
                        <h4 class="text-xs font-bold tracking-tight" ng-style="{color: 'var(--theme-text-main)'}">Rajat Soni</h4>
                        <p class="text-[11px] text-slate-500 font-mono">+91 9001415394</p>
                        <p class="text-[10px] text-slate-400 font-mono truncate">rajat.soni547@gmail.com</p>
                    </div>
                </div>

                <!-- Verified Secure Application Redirect Buttons -->
                <div class="flex items-center gap-2 w-full sm:w-auto justify-end z-10">
                    <a href="https://api.whatsapp.com/send?phone=919001415394" target="_blank" class="apple-glass-btn px-4 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm text-emerald-700 dark:text-emerald-400 hover:bg-emerald-500/20 transition-all cursor-pointer hover:scale-105">
                        <i class="fa-brands fa-whatsapp text-base"></i>
                        Message on WhatsApp
                    </a>
                    <button ng-click="triggerNativeMailRedirect()" class="apple-glass-btn px-4 py-2.5 rounded-xl text-xs font-bold flex items-center gap-2 shadow-sm text-blue-700 dark:text-blue-400 hover:bg-blue-500/20 transition-all cursor-pointer hover:scale-105">
                        <span class="material-symbols-outlined text-base">mail</span>
                        Send Email
                    </button>
                </div>
            </section>

            <!-- ====================================================================
                 VIEWPORT: DASHBOARD OVERVIEW
                 ==================================================================== -->
            <div ng-show="activeView === 'overview'" class="space-y-6 flex flex-col gap-6 animate-fadeIn">
                <!-- TRIPLE SUMMARY CARD CONTAINER LAYER -->
                <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="glass-card p-5 rounded-2xl flex justify-between items-start relative overflow-hidden">
                        <div class="space-y-1.5">
                            <span class="text-xs font-semibold text-slate-500">Today's Profit</span>
                            <h3 class="text-2xl font-black tracking-tight transition-colors" ng-style="{color: 'var(--theme-text-main)'}">$12,426</h3>
                            <span class="text-[10px] text-emerald-600 font-bold bg-emerald-500/10 px-2 py-0.5 rounded flex items-center gap-0.5 w-max">▲ +12%</span>
                        </div>
                        <svg class="w-24 h-12 stroke-blue-600 fill-none opacity-40 self-end mb-1" viewBox="0 0 100 30" stroke-width="2"><path d="M0,25 Q15,10 30,22 T60,5 T90,15 T100,2" /></svg>
                    </div>

                    <div class="glass-card p-5 rounded-2xl flex justify-between items-start relative overflow-hidden">
                        <div class="space-y-1.5">
                            <span class="text-xs font-semibold text-slate-500">Total Sales</span>
                            <h3 class="text-2xl font-black tracking-tight transition-colors" ng-style="{color: 'var(--theme-text-main)'}">$2,38,485</h3>
                            <span class="text-[10px] text-rose-500 font-bold bg-rose-500/10 px-2 py-0.5 rounded flex items-center gap-0.5 w-max">▼ -4.5%</span>
                        </div>
                        <svg class="w-24 h-12 stroke-rose-500 fill-none opacity-40 self-end mb-1" viewBox="0 0 100 30" stroke-width="2"><path d="M0,8 Q20,28 40,12 T75,25 T100,5" /></svg>
                    </div>

                    <div class="glass-card p-5 rounded-2xl flex justify-between items-start relative overflow-hidden">
                        <div class="space-y-1.5">
                            <span class="text-xs font-semibold text-slate-500">Total Orders</span>
                            <h3 class="text-2xl font-black tracking-tight transition-colors" ng-style="{color: 'var(--theme-text-main)'}">84,382</h3>
                            <span class="text-[10px] text-emerald-600 font-bold bg-emerald-500/10 px-2 py-0.5 rounded flex items-center gap-0.5 w-max">▲ +1.8%</span>
                        </div>
                        <svg class="w-24 h-12 stroke-emerald-500 fill-none opacity-40 self-end mb-1" viewBox="0 0 100 30" stroke-width="2"><path d="M0,22 Q25,3 50,18 T100,10" /></svg>
                    </div>
                </section>

                <!-- CHARTS ROW GROUP 01 -->
                <section class="grid grid-cols-1 lg:grid-cols-3 gap-4">
                    <div class="glass-card p-5 rounded-2xl lg:col-span-2 flex flex-col justify-between gap-4 relative min-h-[260px]">
                        <div class="flex justify-between items-center">
                            <h4 class="text-xs font-bold font-mono" ng-style="{color: 'var(--theme-text-main)'}">// MASTER SPLINE TRANSACTION TREND LINES</h4>
                        </div>
                        <div class="h-44 w-full relative flex items-end">
                            <div id="live-graph-dot" class="absolute w-2.5 h-2.5 bg-blue-600 rounded-full border-2 border-white shadow-md z-20 transition-all duration-[1.4s]" style="left: 0px; bottom: 0px;"></div>
                            <svg class="w-full h-full absolute inset-0" viewBox="0 0 600 140" preserveAspectRatio="none">
                                <path d="M0,120 C100,90 200,110 300,60 C400,40 500,80 600,30" id="dynamic-trace-primary" class="animated-svg-path" fill="none" stroke="#2563eb" stroke-width="3" stroke-linecap="round" />
                                <path d="M0,130 C100,110 200,90 300,80 C400,60 500,70 600,45" id="dynamic-trace-secondary" class="animated-svg-path" fill="none" stroke="#f43f5e" stroke-width="1.5" stroke-dasharray="4,4" />
                            </svg>
                        </div>
                        <div class="w-full flex justify-between font-mono text-[9px] text-slate-400 px-1 pt-1 border-t border-slate-900/5">
                            <span>Jan</span><span>Mar</span><span>May</span><span>Jul</span><span>Sep</span><span>Nov</span>
                        </div>
                    </div>

                    <div class="glass-card p-5 rounded-2xl lg:col-span-1 flex flex-col justify-between gap-4">
                        <div class="flex justify-between items-center border-b border-black/5 pb-2">
                            <h4 class="text-xs font-bold transition-colors" ng-class="isDarkMode ? 'text-white' : 'text-slate-800'">Traffic Sources</h4>
                        </div>
                        <div class="space-y-4 flex-grow justify-center flex flex-col">
                            <div class="space-y-1">
                                <div class="flex justify-between text-[11px] font-medium transition-colors" ng-class="isDarkMode ? 'text-slate-300' : 'text-slate-700'"><span>Direct Pipeline</span><span id="txt-prog-a" class="font-bold">70%</span></div>
                                <div class="w-full bg-slate-900/5 h-1.5 rounded-full overflow-hidden"><div id="bar-prog-a" class="bg-blue-600 h-full live-progress w-[70%]"></div></div>
                            </div>
                            <div class="space-y-1">
                                <div class="flex justify-between text-[11px] font-medium transition-colors" ng-class="isDarkMode ? 'text-slate-300' : 'text-slate-700'"><span>External Verification APIs</span><span id="txt-prog-b" class="font-bold">48%</span></div>
                                <div class="w-full bg-slate-900/5 h-1.5 rounded-full overflow-hidden"><div id="bar-prog-b" class="bg-sky-400 h-full live-progress w-[48%]"></div></div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- ADVANCED MONITORING PLOTS ROW GROUP 03 -->
                <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="glass-card p-5 rounded-2xl flex flex-col justify-between gap-2">
                        <h4 class="text-xs font-bold tracking-tight font-mono" ng-style="{color: 'var(--theme-text-main)'}">// ASYNC LOAD BALANCER POOLS</h4>
                        <div class="h-24 flex items-end justify-around gap-1 pt-2">
                            <div class="w-3 bg-primary/30 live-bar rounded-t border-t border-primary" style="height: 60%"></div>
                            <div class="w-3 bg-sky-500/30 live-bar rounded-t border-t border-sky-400" style="height: 35%"></div>
                            <div class="w-3 bg-primary/30 live-bar rounded-t border-t border-primary" style="height: 80%"></div>
                            <div class="w-3 bg-sky-500/30 live-bar rounded-t border-t border-sky-400" style="height: 45%"></div>
                        </div>
                    </div>
                    <div class="glass-card p-5 rounded-2xl flex flex-col justify-between gap-2">
                        <h4 class="text-xs font-bold font-mono" ng-style="{color: 'var(--theme-text-main)'}">// CORE FREQUENCY SPECTRUM</h4>
                        <div class="h-24 w-full pt-1">
                            <svg class="w-full h-full" viewBox="0 0 300 100" preserveAspectRatio="none">
                                <path id="dynamic-frequency-wave" class="animated-svg-path" fill="none" stroke="var(--theme-dna-b)" stroke-width="2.5" d="M0,50 Q30,20 60,70 T120,40 T300,50" />
                            </svg>
                        </div>
                    </div>
                    <div class="glass-card p-5 rounded-2xl flex flex-col justify-between gap-2">
                        <h4 class="text-xs font-bold font-mono" ng-style="{color: 'var(--theme-text-main)'}">// VOLUMETRIC DATA THROUGHPUT RINGS</h4>
                        <div class="flex justify-center items-center h-24 relative">
                            <div id="live-gauge-outer" class="w-16 h-16 rounded-full border-[4px] border-dotted border-primary absolute transition-transform duration-[1.2s]"></div>
                            <div id="live-gauge-inner" class="w-10 h-10 rounded-full border-[3px] border-dashed border-sky-400 absolute transition-transform duration-[1.6s]"></div>
                        </div>
                    </div>
                </section>

                <!-- TELEMETRY COMPLIANCE LOGGER GRID SPREADSHEET -->
                <section class="glass-card p-5 rounded-2xl space-y-3">
                    <div class="flex justify-between items-center">
                        <h4 class="text-xs font-bold tracking-tight" ng-style="{color: 'var(--theme-text-main)'}">Active Processing Ingestion Rows</h4>
                    </div>
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="w-full text-left font-mono text-[11px]" ng-style="{color: 'var(--theme-text-sub)'}">
                            <thead>
                                <tr class="text-slate-400 font-bold uppercase text-[9px] border-b border-black/5">
                                    <th class="pb-2">Order Context ID</th>
                                    <th class="pb-2">Customer Profile Name</th>
                                    <th class="pb-2">Date Frame</th>
                                    <th class="pb-2">Payload Value</th>
                                    <th class="pb-2 text-right">Status Flag</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-black/5">
                                <tr ng-repeat="row in tableData" class="hover:bg-white/20 transition-colors">
                                    <td class="py-2.5 font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.id}}</td>
                                    <td class="font-sans font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.name}}</td>
                                    <td>{{row.date}}</td>
                                    <td class="font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.val}}</td>
                                    <td class="text-right"><span class="bg-emerald-500/10 text-emerald-600 text-[9px] px-2 py-0.5 rounded font-bold">{{row.status}}</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </section>
            </div>

            <!-- ====================================================================
                 VIEWPORT: ADD CUSTOMER DETAILS FORM (NEW REQUEST)
                 ==================================================================== -->
            <div ng-show="activeView === 'add_customer'" class="space-y-6 animate-fadeIn">
                <div class="glass-card p-8 rounded-3xl space-y-6 border-white/60 shadow-xl">
                    <div>
                        <h3 class="text-xl font-bold tracking-tight text-slate-800 border-b border-white/40 pb-3" ng-style="{color: 'var(--theme-text-main)'}"> Add New Customer Profile</h3>
                        <p class="text-xs opacity-70 mt-2 font-mono" ng-style="{color: 'var(--theme-text-sub)'}">// Register and verify new customer identity details into the primary registry framework.</p>
                    </div>

                    <form ng-submit="submitAddCustomerForm()" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 text-sm">
                        <!-- Extended Form Fields -->
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-bold opacity-70 uppercase tracking-widest font-mono" ng-style="{color: 'var(--theme-text-main)'}">Index Trace</label>
                            <input type="text" ng-model="newCustomer.id" placeholder="#CUST-1049" class="w-full bg-white/30 border border-white/50 rounded-2xl px-4 py-3 focus:ring-2 focus:ring-blue-500 transition-all shadow-inner font-mono text-xs" required />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-bold opacity-70 uppercase tracking-widest font-mono" ng-style="{color: 'var(--theme-text-main)'}">Full Name</label>
                            <input type="text" ng-model="newCustomer.name" placeholder="John Doe" class="w-full bg-white/30 border border-white/50 rounded-2xl px-4 py-3 focus:ring-2 focus:ring-blue-500 transition-all shadow-inner text-xs" required />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-bold opacity-70 uppercase tracking-widest font-mono" ng-style="{color: 'var(--theme-text-main)'}">Email Address</label>
                            <input type="email" ng-model="newCustomer.email" placeholder="john.doe@example.com" class="w-full bg-white/30 border border-white/50 rounded-2xl px-4 py-3 focus:ring-2 focus:ring-blue-500 transition-all shadow-inner text-xs" required />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-bold opacity-70 uppercase tracking-widest font-mono" ng-style="{color: 'var(--theme-text-main)'}">Phone Number</label>
                            <input type="tel" ng-model="newCustomer.phone" placeholder="+91 XXXXX XXXXX" class="w-full bg-white/30 border border-white/50 rounded-2xl px-4 py-3 focus:ring-2 focus:ring-blue-500 transition-all shadow-inner text-xs" required />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-[10px] font-bold opacity-70 uppercase tracking-widest font-mono" ng-style="{color: 'var(--theme-text-main)'}">LTV Pool ($)</label>
                            <input type="text" ng-model="newCustomer.val" placeholder="8500" class="w-full bg-white/30 border border-white/50 rounded-2xl px-4 py-3 focus:ring-2 focus:ring-blue-500 transition-all shadow-inner font-mono text-xs" required />
                        </div>

                        <div class="lg:col-span-3 pt-2">
                            <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 border border-white/20 font-bold rounded-2xl py-3.5 text-white shadow-lg hover:scale-[1.01] transition-transform text-sm tracking-wide">
                                <i class="fa-solid fa-user-plus mr-2"></i> Register Customer Identity
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ====================================================================
                 VIEWPORT: CUSTOMERS REGISTRY TABLE
                 ==================================================================== -->
            <div ng-show="activeView === 'customers' || activeView === 'add_customer'" class="space-y-6 animate-fadeIn">
                <!-- CUSTOMER LIST DATA MATRIX -->
                <div class="glass-card p-6 rounded-3xl space-y-4 border-white/60">
                    <h3 class="text-sm font-semibold tracking-tight text-slate-800 border-b border-white/40 pb-2" ng-style="{color: 'var(--theme-text-main)'}">Customer Registry Records</h3>
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="w-full text-left font-mono text-[11px]" ng-style="{color: 'var(--theme-text-sub)'}">
                            <thead>
                                <tr class="text-slate-400 font-bold uppercase text-[9px] border-b border-black/5">
                                    <th class="pb-2">Customer ID</th>
                                    <th class="pb-2">Account Name</th>
                                    <th class="pb-2">Contact Details</th>
                                    <th class="pb-2">Date Added</th>
                                    <th class="pb-2">LTV Contribution</th>
                                    <th class="pb-2 text-right">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-black/5">
                                <tr ng-repeat="row in customerData" class="hover:bg-white/20 transition-colors">
                                    <td class="py-2.5 font-bold text-blue-600 dark:text-sky-400">{{row.id}}</td>
                                    <td class="font-sans font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.name}}</td>
                                    <td class="opacity-70 text-[9px]">{{row.email || 'N/A'}}</td>
                                    <td>{{row.date}}</td>
                                    <td class="font-bold text-emerald-600">{{row.val}}</td>
                                    <td class="text-right"><span class="bg-blue-500/10 text-blue-600 dark:text-blue-400 text-[9px] px-2 py-0.5 rounded font-bold">{{row.status}}</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- ====================================================================
                 VIEWPORT: SHIPPING & LOGISTICS (GOOGLE MAP AND TRACKER)
                 ==================================================================== -->
            <div ng-show="activeView === 'shipping'" class="space-y-6 animate-fadeIn">
                <!-- MAP AND LOGISTICS INGESTION ROW -->
                <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                    <!-- GOOGLE MAPS INTEGRATION & GEOLOCATION -->
                    <div class="glass-card p-6 rounded-3xl space-y-4 flex flex-col h-[400px] relative overflow-hidden">
                        <div class="flex justify-between items-center border-b border-slate-900/5 pb-2">
                            <h3 class="text-xs font-black font-mono" ng-style="{color: 'var(--theme-text-main)'}">// LIVE GPS ROUTING MAP</h3>
                            <button ng-click="locateMe()" class="text-[10px] font-bold bg-blue-500/10 text-blue-600 dark:text-sky-400 px-3 py-1.5 rounded-lg flex items-center gap-1.5 hover:bg-blue-500/20 transition-colors z-10 cursor-pointer border border-blue-500/30">
                                <span class="material-symbols-outlined text-sm">my_location</span> Track My Current Location
                            </button>
                        </div>

                        <div class="w-full h-full rounded-2xl overflow-hidden relative shadow-inner border border-white/20">
                            <!-- Trusted Dynamic Iframe Src bounds via Angular $sce -->
                            <iframe ng-src="{{mapUrl}}" width="100%" height="100%" style="border:0; filter: saturate(1.2);" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="transition-all duration-500"></iframe>
                        </div>
                    </div>

                    <div class="flex flex-col gap-6">
                        <!-- SVG TRACER SUPPLEMENT MAP -->
                        <div class="glass-card p-6 rounded-3xl space-y-4 flex flex-col items-center">
                            <h3 class="text-xs font-black font-mono border-b border-slate-900/5 pb-2 w-full text-center" ng-style="{color: 'var(--theme-text-main)'}">// INTERNAL LOGISTICS NETWORK TOPOLOGY</h3>
                            <div class="relative w-full max-w-[200px] h-32 mt-2">
                                <svg viewBox="0 0 400 400" class="w-full h-full drop-shadow-[0_0_15px_rgba(37,99,235,0.4)]">
                                    <path id="route-path-main" d="M140,120 L100,220 L160,320 L190,340" fill="none" stroke="var(--theme-primary)" stroke-width="2.5" stroke-dasharray="6,6" class="opacity-60" />
                                    <path d="M140,120 L180,80 L260,200 L190,340" fill="none" stroke="var(--theme-dna-b)" stroke-width="1.5" stroke-dasharray="4,4" class="opacity-50" />
                                    <circle cx="180" cy="80" r="5" fill="var(--theme-primary)" />
                                    <text x="192" y="84" font-size="16" fill="var(--theme-text-main)" font-weight="bold">Delhi</text>
                                    <circle cx="140" cy="120" r="7" fill="#f43f5e" />
                                    <text x="30" y="124" font-size="16" fill="var(--theme-text-main)" font-weight="bold">Jaipur</text>
                                    <circle cx="100" cy="220" r="5" fill="var(--theme-primary)" />
                                    <text x="10" y="224" font-size="16" fill="var(--theme-text-main)" font-weight="bold">Mumbai</text>
                                    <circle cx="160" cy="320" r="5" fill="var(--theme-primary)" />
                                    <text x="50" y="324" font-size="16" fill="var(--theme-text-main)" font-weight="bold">BLR</text>
                                    <circle r="6" fill="#10b981" filter="drop-shadow(0 0 8px #10b981)"><animateMotion dur="6s" repeatCount="indefinite"><mpath href="#route-path-main" /></animateMotion></circle>
                                </svg>
                            </div>
                        </div>

                        <!-- NEW SHIPPING INGESTION FORM -->
                        <div class="glass-card p-6 rounded-3xl space-y-4 flex-grow">
                            <h3 class="text-xs font-black font-mono border-b border-slate-900/5 pb-2" ng-style="{color: 'var(--theme-text-main)'}">[LOGISTICS] // DISPATCH NEW SHIPMENT</h3>
                            <form ng-submit="submitShipping()" class="space-y-4 text-xs font-mono">
                                <input type="text" ng-model="formShipping.id" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2.5 shadow-inner" placeholder="Tracking Trace (#TRK-...)" required />
                                <input type="text" ng-model="formShipping.name" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2.5 shadow-inner" placeholder="Destination Hub (e.g. Mumbai)" required />
                                <input type="text" ng-model="formShipping.val" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2.5 shadow-inner" placeholder="Package Value / Insurance ($)" required />
                                <select ng-model="formShipping.status" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2.5 shadow-inner font-bold text-blue-700">
                                    <option value="IN TRANSIT">IN TRANSIT</option>
                                    <option value="DISPATCHED">DISPATCHED</option>
                                    <option value="DELIVERED">DELIVERED</option>
                                </select>
                                <button type="submit" class="w-full bg-gradient-to-r from-emerald-500 to-teal-400 text-white rounded-xl py-3 font-bold shadow-md hover:scale-[1.02] transition-transform">INITIALIZE_DISPATCH_PROTOCOL</button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- ACTIVE SHIPPING TRACKING GRID -->
                <div class="glass-card p-6 rounded-3xl space-y-4">
                    <h3 class="text-sm font-semibold tracking-tight text-slate-800 border-b border-slate-900/5 pb-2" ng-style="{color: 'var(--theme-text-main)'}">Active Logistics Fleet Operations</h3>
                    <div class="overflow-x-auto custom-scrollbar">
                        <table class="w-full text-left font-mono text-[11px]" ng-style="{color: 'var(--theme-text-sub)'}">
                            <thead>
                                <tr class="text-slate-400 font-bold uppercase text-[9px] border-b border-black/5">
                                    <th class="pb-2">Tracking Node</th>
                                    <th class="pb-2">Destination Hub</th>
                                    <th class="pb-2">Timestamp Last Ping</th>
                                    <th class="pb-2">Cargo Value</th>
                                    <th class="pb-2 text-right">Route Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-black/5">
                                <tr ng-repeat="row in shippingData" class="hover:bg-white/20 transition-colors">
                                    <td class="py-2.5 font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.id}}</td>
                                    <td class="font-sans font-bold" ng-style="{color: 'var(--theme-text-main)'}">{{row.name}}</td>
                                    <td>{{row.date}}</td>
                                    <td class="font-bold text-rose-600">{{row.val}}</td>
                                    <td class="text-right">
                                        <span ng-if="row.status === 'DELIVERED'" class="bg-emerald-500/10 text-emerald-600 text-[9px] px-2 py-0.5 rounded font-bold">{{row.status}}</span>
                                        <span ng-if="row.status === 'IN TRANSIT'" class="bg-blue-500/10 text-blue-600 text-[9px] px-2 py-0.5 rounded font-bold">{{row.status}}</span>
                                        <span ng-if="row.status === 'DISPATCHED'" class="bg-amber-500/10 text-amber-600 text-[9px] px-2 py-0.5 rounded font-bold">{{row.status}}</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- COMPONENT FORMS WORKSPACE LINK OPTIONS MAP -->
            <div ng-show="activeView === 'orders'" class="glass-card p-6 rounded-3xl space-y-4 animate-fadeIn">
                <h3 class="text-xs font-black font-mono border-b border-slate-900/5 pb-2" ng-style="{color: 'var(--theme-text-main)'}">[DESIGN_A] // NEUMORPHIC GRID CONTROLS</h3>
                <form ng-submit="submitFormA()" class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs font-mono">
                    <input type="text" ng-model="formA.id" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2 shadow-inner" placeholder="#ORD-99A" required />
                    <input type="text" ng-model="formA.name" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2 shadow-inner" placeholder="Ayan Ahmed" required />
                    <input type="text" ng-model="formA.val" class="w-full bg-white/50 border-0 rounded-xl px-3 py-2 shadow-inner" placeholder="12500" required />
                    <button type="submit" class="md:col-span-2 bg-gradient-to-r from-blue-600 to-sky-500 text-white rounded-xl py-2 font-bold shadow-md">EXECUTE_NEUMORPHIC_INGESTION</button>
                </form>
            </div>

            <div ng-show="activeView === 'products'" class="glass-card p-6 rounded-3xl space-y-4 bg-slate-950/80 text-slate-200 border-white/10 shadow-2xl animate-fadeIn">
                <h3 class="text-xs font-bold font-mono text-cyan-400 border-b border-white/10 pb-2">// [DESIGN_B] OBSIDIAN CYBER REPLICATOR PLATFORM</h3>
                <form ng-submit="submitFormB()" class="space-y-4 text-xs font-mono">
                    <input type="text" ng-model="formB.id" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-cyan-300" placeholder="#PRD-88B" required />
                    <input type="text" ng-model="formB.name" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-cyan-300" placeholder="Lokesh Kavadia" required />
                    <input type="text" ng-model="formB.val" class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-cyan-300" placeholder="1234" required />
                    <button type="submit" class="w-full bg-cyan-500 text-slate-950 rounded-lg py-2 font-bold">COMMIT_MICRO_RECORD</button>
                </form>
            </div>

            <div ng-show="activeView === 'finances'" class="glass-card p-6 rounded-3xl space-y-4 border-orange-300 shadow-lg animate-fadeIn">
                <h3 class="text-xs font-black uppercase tracking-wider text-orange-700 border-b border-orange-200 pb-2">// [DESIGN_D] SUNSET RISK BALANCING CONSOLE</h3>
                <form ng-submit="submitFormD()" class="space-y-4 text-xs font-mono">
                    <input type="text" ng-model="formD.id" placeholder="LEDGER_NODE" class="w-full bg-white border-2 border-orange-400 rounded-xl px-3 py-1.5" required />
                    <input type="text" ng-model="formD.name" placeholder="ACCOUNT_REF" class="w-full bg-white border-2 border-orange-400 rounded-xl px-3 py-1.5" required />
                    <input type="range" min="100" max="15000" ng-model="formD.val" class="w-full accent-orange-600" />
                    <button type="submit" class="w-full bg-orange-600 text-white font-extrabold rounded-xl py-2.5 tracking-widest">PIPELINE_sunset_MUTATION</button>
                </form>
            </div>
        </main>
    </div>

    <!-- REPLICATION CONTROLS RUNTIME ENGINE -->
    <script src="~/js/dashboard.js"></script>
</body>
</html>